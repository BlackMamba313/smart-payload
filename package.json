{
  "name": "smart-payload",
  "version": "1.0.0",
  "description": "Framework-agnostic payload serializer for JSON, FormData, and URLSearchParams.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fetch": {
      "types": "./dist/adapters/fetch.d.ts",
      "import": "./dist/adapters/fetch.js",
      "require": "./dist/adapters/fetch.cjs"
    },
    "./axios": {
      "types": "./dist/adapters/axios.d.ts",
      "import": "./dist/adapters/axios.js",
      "require": "./dist/adapters/axios.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "formdata",
    "serialization",
    "fetch",
    "axios",
    "typescript"
  ],
  "author": "Aleksej Konstantinov",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlackMamba313/smart-payload.git"
  },
  "homepage": "https://github.com/BlackMamba313/smart-payload#readme",
  "bugs": {
    "url": "https://github.com/BlackMamba313/smart-payload/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "axios": ">=1.4.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.8"
  }
}
